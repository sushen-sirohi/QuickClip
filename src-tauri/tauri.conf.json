{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickClip",
  "version": "0.1.0",
  "identifier": "com.quickclip.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "QuickClip",
        "width": 600,
        "height": 500,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "focus": true,
        "transparent": false,
        "closable": true,
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "QuickClip - Cmd+Shift+V"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}